{
  "manifest_version": 3,
  "name": "AI Data Extractor",
  "version": "2.0",
  "description": "Extract ML-ready datasets from websites and medical OCR files.",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}